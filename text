Class ConsumerWorker:
  __init__(self, redis_url, drone_id):
    self.drone_id = drone_id
    self.stream_key = f"telemetry:{drone_id}"
    self.scores_channel = f"scores:{drone_id}"
    self.redis = redis.from_url(redis_url)
    self.scoring = ScoringEngine()
    self.alert = AlertEngine()
    self.last_id = "0"  (read from beginning on start)

  async run(self):
    Infinite loop:
      Read from Redis Stream using XREAD:
        COUNT 10, BLOCK 1000ms, streams {self.stream_key: self.last_id}
      For each message:
        Parse "data" field as JSON to get the packet
        Update self.last_id to current message ID
        Pass packet to scoring engine
        Get scores dict back
        Add drone_id and timestamp to scores
        Publish scores to Redis PubSub channel self.scores_channel as JSON
      On error: log and sleep 2s

--- workers/scoring_engine.py ---
Class ScoringEngine:
  Maintains rolling state per message type using a dict self.state
  
  score(self, packet) -> dict:
    Updates self.state with latest values from packet
    Computes and returns these 8 scores (all 0-100 float, higher=healthier):
    
    pwr (power score):
      From SYS_STATUS: voltage_battery (mV), battery_remaining (%)
      voltage_battery: 100 if >11800mV, 0 if <10500mV, linear between
      battery_remaining: use directly as 0-100
      pwr = (voltage_score * 0.4) + (battery_remaining * 0.6)
      If no SYS_STATUS data yet: return 50
    
    imu (IMU health score):
      From SCALED_IMU: xacc, yacc, zacc (mg), xgyro, ygyro, zgyro (mrad/s)
      accel_magnitude = sqrt(xacc^2 + yacc^2 + zacc^2)
      Expected ~1000mg (1g). Score 100 if 900-1100, degrades outside that range, 0 if <500 or >1500
      gyro_magnitude = sqrt(xgyro^2 + ygyro^2 + zgyro^2)
      gyro_score: 100 if <50, 0 if >500, linear between
      imu = (accel_score * 0.5) + (gyro_score * 0.5)
      If no SCALED_IMU data yet: return 50
    
    ekf (EKF health score):
      From EKF_STATUS_REPORT: flags, velocity_variance, pos_horiz_variance, pos_vert_variance, compass_variance
      flag_score: 100 if flags >= 0x1F (all healthy bits set), 50 if flags > 0, 0 if flags == 0
      variance_score: average of 4 variances, score 100 if avg<0.1, 0 if avg>1.0, linear
      ekf = (flag_score * 0.6) + (variance_score * 0.4)
      If no EKF data yet: return 50
    
    gps (GPS health score):
      From GPS_RAW_INT: fix_type, satellites_visible, eph (hdop*100)
      fix_score: 0→0, 1→10, 2→50, 3→80, 4→100, 5+→100
      sat_score: 0 if sats<4, linear 0-100 for 4-12 sats, 100 if >12
      hdop_score: 100 if eph<150, 0 if eph>500, linear between
      gps = (fix_score*0.4) + (sat_score*0.3) + (hdop_score*0.3)
      If no GPS data yet: return 50
    
    ctl (control score):
      From ATTITUDE: roll, pitch (radians)
      From VFR_HUD: groundspeed
      roll_score: 100 if abs(roll)<0.1, 0 if abs(roll)>0.5, linear
      pitch_score: 100 if abs(pitch)<0.1, 0 if abs(pitch)>0.5, linear
      ctl = (roll_score * 0.5) + (pitch_score * 0.5)
      If no ATTITUDE data: return 50
    
    mot (motor/output score):
      From RC_CHANNELS_RAW: chan1_raw to chan4_raw (PWM values 1000-2000)
      For each channel: score 100 if 1000-2000, 0 if outside range
      Check balance: max_chan - min_chan, score 100 if diff<200, 0 if diff>600
      mot = (range_score * 0.5) + (balance_score * 0.5)
      If no RC data: return 50
    
    com (comms score):
      From SYS_STATUS: drop_rate_comm (percentage * 100)
      com = 100 if drop_rate==0, linear down to 0 if drop_rate>=5000 (50%)
      From HEARTBEAT: track time since last heartbeat
      heartbeat_score: 100 if <2s ago, 0 if >5s ago, linear
      com = (drop_score * 0.5) + (heartbeat_score * 0.5)
      If no data: return 50
    
    composite:
      weighted average:
      (pwr*0.20) + (imu*0.15) + (ekf*0.20) + (gps*0.15) + (ctl*0.10) + (mot*0.10) + (com*0.10)
      Round all scores to 2 decimal places

